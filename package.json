{
  "name": "barosit",
  "private": true,
  "version": "0.9.9",
  "type": "module",
  "scripts": {
    "vendor:mediapipe": "node scripts/vendor-mediapipe.mjs",
    "predev": "node scripts/vendor-mediapipe.mjs",
    "dev": "vite",
    "prebuild": "node scripts/vendor-mediapipe.mjs",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "predev:web": "node scripts/vendor-mediapipe.mjs",
    "dev:web": "VITE_PLATFORM=web vite --port 1430 --strictPort",
    "prebuild:web": "node scripts/vendor-mediapipe.mjs",
    "build:web": "tsc && VITE_PLATFORM=web vite build --outDir dist-web && node scripts/copy-functions.mjs",
    "preview:web": "vite preview --outDir dist-web --port 1430 --strictPort",
    "test": "vitest run",
    "qa": "node qa/runner.mjs",
    "qa:checklist": "node qa/scripts/extract-checklist.mjs",
    "qa:merge": "node qa/scripts/merge-results.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@mediapipe/tasks-vision": "^0.10.18",
    "@supabase/supabase-js": "^2.106.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-autostart": "^2",
    "@tauri-apps/plugin-deep-link": "^2.4.9",
    "@tauri-apps/plugin-notification": "^2",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-store": "^2",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "i18next": "^26.3.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "jsdom": "^25.0.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^2.1.9"
  }
}

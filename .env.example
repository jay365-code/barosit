# Supabase 인증 + DB
# https://supabase.com 에서 프로젝트 생성 후 Settings → API 에서 복사
# anon key 는 public 노출 OK (RLS 가 데이터 보호)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.example...

# OAuth 콜백 URL 의 base (보통 자동 감지되므로 비워둬도 됨)
# 명시 시: dev → http://localhost:1430, prod → https://barosit.com
# VITE_AUTH_REDIRECT_BASE=

# 런치 모드 (빌드타임 기본값). 미설정 시 'paid'.
#  - beta_free : 페이월 숨김 + 전원 PRO 개방 (무료 베타 출시)
#  - paid      : 정상 구독 게이팅
# 부팅 시 Supabase app_config.launch_mode 원격값이 있으면 이 값을 override 함.
# VITE_LAUNCH_MODE=paid

# Toss Payments 클라이언트 키 (결제). 테스트키는 test_gck_..., 운영키는 live_gck_...
# 필수 — 미설정 시 결제 시도가 즉시 에러로 중단된다(폴백 없음).
# 서버의 TOSS_SECRET_KEY 와 반드시 같은 상점·같은 환경(test/live)이어야 빌링키 발급이 성립한다.
# 배포 환경(Cloudflare Pages)에도 동일하게 등록할 것.
# VITE_TOSS_CLIENT_KEY=test_gck_xxxxxxxxxxxxxxxx

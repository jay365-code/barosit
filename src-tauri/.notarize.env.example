# macOS 서명+공증용 자격증명 양식.
# 이 파일을 같은 폴더에 ".notarize.env" 로 복사한 뒤 실제 값으로 채우세요.
# (.notarize.env 는 .gitignore 로 git에 절대 안 올라갑니다)

# Apple Developer 계정 이메일(Apple ID)
APPLE_ID="you@example.com"

# appleid.apple.com 에서 발급한 앱 암호 (xxxx-xxxx-xxxx-xxxx)
APPLE_PASSWORD="xxxx-xxxx-xxxx-xxxx"

# 조직 팀 ID (Developer ID 인증서 기준 — 변경 불필요)
APPLE_TEAM_ID="LHR4658746"

# (선택) Tauri 자동 업데이터 서명용 Ed25519 개인키. tauri.conf.json 의 pubkey 와 짝.
# 과거 릴리스에 쓰던 그 키. 없으면 .app/.dmg 공증은 되지만 updater(latest.json 서명) 산출 실패.
# 키 본문(여러 줄)이면 파일경로 대신 본문을, 또는 base64 한 줄을 넣으세요.
# TAURI_SIGNING_PRIVATE_KEY=""
# TAURI_SIGNING_PRIVATE_KEY_PASSWORD=""

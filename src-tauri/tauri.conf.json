{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BaroSit",
  "version": "0.1.6",
  "identifier": "com.barosit.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "BaroSit",
        "width": 1100,
        "height": 940,
        "minWidth": 800,
        "minHeight": 640,
        "resizable": true,
        "minimizable": true,
        "fullscreen": false,
        "backgroundColor": "#fafaf7",
        "titleBarStyle": "Visible"
      },
      {
        "label": "widget",
        "title": "BaroSit 위젯",
        "url": "index.html#widget",
        "width": 340,
        "height": 380,
        "x": 40,
        "y": 60,
        "decorations": false,
        "transparent": true,
        "backgroundColor": "#00000000",
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": false,
        "shadow": true
      },
      {
        "label": "alert",
        "title": "BaroSit 알림",
        "url": "index.html#alert",
        "width": 1280,
        "height": 800,
        "decorations": false,
        "transparent": true,
        "backgroundColor": "#00000000",
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": false,
        "shadow": false,
        "focus": false,
        "acceptFirstMouse": false,
        "maximizable": false,
        "minimizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/jay365-code/barosit/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU0RjMwMTM1NjRGMTFENjIKUldSaUhmRmtOUUh6NUN0VXJLVFVScE1kaUxXZnZkbVhJMk5hbEJxeUpxZUZxcUNzWWR0OGxwaEQK"
    }
  }
}
